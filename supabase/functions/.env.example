# 复制为同目录下的 .env 并填写（勿提交 .env）。
# 本地 npx supabase start 会加载本文件；supabase secrets set 只作用于云端部署。
#
# 若业务自定义域名网关对 storage/upload 存在签名兼容问题，可为函数内部 admin client 指定项目原生域名：
# SUPABASE_ADMIN_URL=https://<project-ref>.supabase.co
# 若希望写入数据库的文件地址可被外网直接访问，可显式指定对外访问域名（例如你的自定义网关域名）：
# SUPABASE_PUBLIC_URL=https://www.hbjtnqf.cn
#
# create-signing 走 contractFileStorage（推荐，避免大 JSON 触发 Edge CPU limit）时，Functions 进程需能下载 Storage：
# SUPABASE_SERVICE_ROLE_KEY=<与项目 service_role 一致；自建一般在 docker-compose.functions 里已注入，缺则手动补>

ASIGN_APP_ID=997407968
ASIGN_PRIVATE_

# 可选
# ASIGN_BASE_URL=https://prev.asign.cn

# 添加签署方：须为 contract/addSigner（勿写成 contract/addSign，否则会参数异常）
# ASIGN_ADD_SIGNATORY_PATH=contract/addSigner
# signStrategyList 文档为 List{Object}，默认传数组；仅特殊环境需要字符串时再设 ASIGN_SIGN_STRATEGY_LIST_AS_STRING=1
# ASIGN_SIGN_STRATEGY_LIST_AS_STRING=0
# 有 signStrategyList 时 customSignFlag 默认 0（由策略指定位置）；一般无需改
# ASIGN_DEFAULT_CUSTOM_SIGN_FLAG=0
# 有感知签(signType=3)时默认补 validateType=1（短信意愿）；若与业务冲突可设 ASIGN_SKIP_DEFAULT_VALIDATE_FOR_PERCEIVED=1
# ASIGN_SKIP_DEFAULT_VALIDATE_FOR_PERCEIVED=0
# 未在请求里传 signType / isNotice / validateType 时，Edge 使用的默认值：
# ASIGN_DEFAULT_SIGN_TYPE=3
# ASIGN_DEFAULT_IS_NOTICE=1
# 未传 validateType 时 Edge 写入（signType=3 且未设 ASIGN_SKIP_DEFAULT_VALIDATE_FOR_PERCEIVED=1 时默认 1=短信验证码签）
# 手签+H5 逐字书写：请求体应显式传 6 或 7（仅个人）；企业常用 16。见 add-asign-signatory 注释。
# ASIGN_DEFAULT_VALIDATE_TYPE=1
# 企业签署方默认印章编号：当前端 signers[i].isEnterpriseSigner=true 且未传 sealNo 时，Edge 自动注入
# ASIGN_ENTERPRISE_SEAL_NO=
# sortAndFilterObject 需保留的空串字段（逗号分隔，一般不必配）
# ASIGN_ADD_SIGNATORY_KEEP_EMPTY_KEYS=
# addSigner 的 signOrder：文档多为字符串；若仍报泛化「参数异常」可试改为数字 JSON：ASIGN_ADD_SIGNER_SIGN_ORDER_AS_NUMBER=1
# ASIGN_ADD_SIGNER_SIGN_ORDER_AS_NUMBER=0

# 主动下载已签合同 PDF（Edge：download-asign-contract → contract/downloadContract）
# 默认路径 contract/downloadContract；若开放平台路径不同可覆盖
# ASIGN_DOWNLOAD_CONTRACT_PATH=contract/downloadContract
# 大文件超时（毫秒，默认 60000）
# ASIGN_DOWNLOAD_TIMEOUT_MS=60000
# 签名校验重试次数上限（默认 4）
# ASIGN_DOWNLOAD_MAX_ATTEMPTS=4
# 批量/连续请求时爱签或前置网关偶发 502：整单重试次数与间隔（毫秒，第 n 次等待 ≈ n * 间隔）
# ASIGN_DOWNLOAD_GATEWAY_RETRY_WAVES=4
# ASIGN_DOWNLOAD_GATEWAY_RETRY_DELAY_MS=900

# 爱签 createContract 可选字段（公网 HTTPS，爱签服务器可访问；勿用 127.0.0.1）
# notifyUrl：异步通知（本仓库 Edge Function asign-notify，已实现）
# 签署完成后爱签 POST 到此 URL；回调体须能解析出 contractNo，且含 PDF base64 或可公网 GET 的 PDF 直链
#（否则会仅打日志 [ASIGN_NOTIFY]，不落库）。需配置 Functions 的 SUPABASE_SERVICE_ROLE_KEY 以便写入库与 Storage。
# 生产示例：https://<project-ref>.supabase.co/functions/v1/asign-notify
# 本地调试：用 ngrok 暴露到公网后填完整 URL
ASIGN_NOTIFY_URL=http://43.226.47.134:28000/functions/v1/asign-notify
# ASIGN_CALLBACK_URL=https://你的域名/api/asign/callback
# ASIGN_REDIRECT_URL=https://你的域名/sign/return

# 爱签「异步通知」回调验签：平台公钥（文档中的爱签公钥，PEM 或 Base64 DER）
# 仅 ASCII 一行 Base64 也可；配置后 asign-notify 将强制校验 sign，否则返回 401
# ASIGN_PLATFORM_PUBLIC_KEY=MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJB...
# 若 SHA-256 验签不过可尝试：ASIGN_NOTIFY_VERIFY_HASH=SHA-1

# 签名仍报 100016 时，在「本地」请写进本文件（不要光靠 secrets set）：
# ASIGN_SIGN_HASH=SHA1
# ASIGN_SIGN_PLAINTEXT_MODE=bizdata_only
# 与爱签 Node 官方示例一致：ASIGN_SIGN_PLAINTEXT_MODE=official_concat（较耗 CPU，慎用）
#
# 带 PDF：默认跑满 attempts（含 official）。无 PDF（如 addSigner）：默认 ASIGN_MAX_ATTEMPTS_NO_FILES=4，防 wall clock。
# ASIGN_MAX_ATTEMPTS_WITH_FILES=
# ASIGN_MAX_ATTEMPTS_NO_FILES=4
# 两种请求统一上限（可选）：ASIGN_MAX_ATTEMPTS=7
